# Document root: this .htaccess must sit in the SAME folder that is the domain’s
# "Document root" in cPanel. If the domain points to public_html/ but the site is
# only in public_html/some-subfolder/, you will get 403 — either move the files up to
# public_html/ or in cPanel → Domains → change Document Root for barbergarage.bg to
# that subfolder.
#
# Optional: if the site is in a sub-URL, uncomment ONE RewriteBase to match, e.g.
# RewriteBase /barbergarage/

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  # /en -> /en/
  RewriteRule ^en$ en/ [R=301,L,NC]
  # Optional clean URLs: redirect .../index.html to .../  (use after Document Root is fixed)
  # RewriteBase /
  # RewriteRule ^index\.html$ / [R=301,L,NE]
  # RewriteRule ^en/index\.html$ /en/ [R=301,L,NE]
</IfModule>
