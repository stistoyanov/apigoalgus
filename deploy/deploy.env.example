# Copy to deploy.env and adjust if needed:
#   cp deploy/deploy.env.example deploy/deploy.env

DEPLOY_SSH_HOST=goalgus.bg
DEPLOY_SSH_PORT=1022
DEPLOY_SSH_USER=goalgusb
DEPLOY_REMOTE_PATH=public_html/apigoalgus

# PHP binary on Superhosting (run `which php` over SSH to verify)
DEPLOY_PHP_BIN=php

# Composer command on server (adjust if composer is elsewhere)
DEPLOY_COMPOSER=composer
